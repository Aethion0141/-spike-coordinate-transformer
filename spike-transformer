import torch
import torch.nn as nn
import torch.nn.functional as F
import time

class SpikeCoordinateTransformer(nn.Module):
    """
    Pure Spike-Coordinate Transformer - No multi-agent, just pure architecture
    """
    def __init__(self, d_model=128, n_heads=4, spike_timesteps=32, window_size=128):
        super().__init__()
        self.d_model = d_model
        self.spike_timesteps = spike_timesteps
        self.window_size = window_size
        self.n_heads = n_heads
        self.head_dim = d_model // n_heads
        
        # Step 1: Encode to spikes
        self.spike_encoder = nn.Linear(d_model, spike_timesteps)
        
        # Step 2: QKV projections for spike attention
        self.q_proj = nn.Linear(spike_timesteps, d_model)
        self.k_proj = nn.Linear(spike_timesteps, d_model)
        self.v_proj = nn.Linear(spike_timesteps, d_model)
        self.out_proj = nn.Linear(d_model, d_model)
        
        # Step 3: Output reconstruction
        self.output_layer = nn.Linear(d_model, d_model)
        
    def encode_to_spikes(self, x):
        """Convert input to binary spikes"""
        # Project to spike timesteps
        spike_logits = self.spike_encoder(x)  # (B, seq, T)
        # Convert to probabilities
        spike_probs = torch.sigmoid(spike_logits)
        # Make binary (spike or no spike)
        spikes = (spike_probs > 0.5).float()
        return spikes
    
    def compute_coordinate_distances(self, x):
        """Distance between tokens = attention weight"""
        # Normalize for stable distance
        x_norm = F.normalize(x, p=2, dim=-1)
        # Cosine distance (1 - similarity)
        sim = torch.bmm(x_norm, x_norm.transpose(1, 2))
        dist = 1 - sim
        return dist
    
    def spike_attention(self, spikes, distances):
        """Attention using spike patterns and distances"""
        batch, seq, T = spikes.shape
        
        # Project spikes to Q, K, V
        q = self.q_proj(spikes).view(batch, seq, self.n_heads, self.head_dim)
        k = self.k_proj(spikes).view(batch, seq, self.n_heads, self.head_dim)
        v = self.v_proj(spikes).view(batch, seq, self.n_heads, self.head_dim)
        
        # Spike-timing attention
        attn = torch.einsum('bqhd,bkhd->bhqk', q, k) / (self.head_dim ** 0.5)
        
        # Apply coordinate distance penalty (far away = less attention)
        distance_penalty = torch.exp(-distances.unsqueeze(1) * 2.0)
        attn = attn + distance_penalty.log().clamp(-10, 10)
        
        # Softmax and apply
        attn_weights = F.softmax(attn, dim=-1)
        out = torch.einsum('bhqk,bkhd->bqhd', attn_weights, v)
        out = out.reshape(batch, seq, -1)
        
        return self.out_proj(out)
    
    def forward(self, x):
        # Step 1: Convert to spikes
        spikes = self.encode_to_spikes(x)
        
        # Step 2: Compute distances (coordinates)
        distances = self.compute_coordinate_distances(x)
        
        # Step 3: Spike attention with distance modulation
        attended = self.spike_attention(spikes, distances)
        
        # Step 4: Final output
        output = self.output_layer(attended)
        
        return output, spikes, distances


