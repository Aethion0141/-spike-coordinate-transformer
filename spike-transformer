    print(f"Distances shape: {distances.shape}")
    print(f"Output shape: {output.shape}")
    print(f"Spike density: {spikes.mean().item():.2%}")
    print(f"Inference time: {elapsed*1000:.2f}ms")
    
    print("\n✅ SPIKE-COORDINATE TRANSFORMER READY")
    print("   - Binary spikes (efficient)")
    print("   - Distance = attention weight")
    print("   - No multi-agent, pure architecture")
